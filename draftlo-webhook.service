[Unit]
Description=Draftlo Deploy Webhook Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/draftlo
ExecStart=/usr/bin/node /root/draftlo/webhook-server.js
Restart=always
RestartSec=10
Environment=WEBHOOK_PORT=9000
Environment=WEBHOOK_SECRET=REPLACE_WITH_YOUR_SECRET
Environment=DEPLOY_DIR=/root/draftlo

[Install]
WantedBy=multi-user.target
